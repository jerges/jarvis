# Copia este fichero como .env y rellena los valores reales
# cp .env.example .env

# ── Anthropic (obligatorio) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Azure AI Foundry (opcional) ────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_ORCHESTRATOR_DEPLOYMENT=gpt-4o
AZURE_AGENT_DEPLOYMENT=gpt-4o-mini

# ── Proveedor por defecto: ANTHROPIC | AZURE | CLAUDE_CLI | OLLAMA ─────────────
JARVIS_DEFAULT_PROVIDER=ANTHROPIC

# ── Claude CLI (opcional — perfil claude-cli) ──────────────────────────────────
CLAUDE_CLI_COMMAND=claude
CLAUDE_CLI_ORCHESTRATOR_MODEL=haiku
CLAUDE_CLI_AGENT_MODEL=haiku
CLAUDE_CLI_TIMEOUT_SECONDS=180

# ── Telegram Bot (opcional) ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ── WhatsApp Cloud API (opcional) ──────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# ── Google OAuth — Drive, Gmail y Calendar (opcional) ─────────────────────────
# 1. Crea credenciales OAuth 2.0 en https://console.cloud.google.com
# 2. Tipo: Web application. Redirect URI: http://localhost:8080/api/google/oauth/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/google/oauth/callback
# true: conexión compartida para todas las conversaciones (recomendado)
# false: conexión independiente por conversationId
GOOGLE_OAUTH_SHARED_CONNECTION=true
